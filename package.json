{
  "name": "claude-code-katex",
  "displayName": "Claude Code KaTeX",
  "description": "Adds LaTeX math rendering to Claude Code chat using KaTeX",
  "version": "1.6.0",
  "publisher": "nuriyev",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahammadNuriyev62/claude-code-katex.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "katex",
    "latex",
    "math",
    "rendering",
    "anthropic",
    "claude-code"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-katex.enable",
        "title": "Claude Code KaTeX: Enable LaTeX Rendering"
      },
      {
        "command": "claude-code-katex.disable",
        "title": "Claude Code KaTeX: Disable LaTeX Rendering"
      },
      {
        "command": "claude-code-katex.status",
        "title": "Claude Code KaTeX: Check Status"
      }
    ]
  },
  "scripts": {
    "test": "jest",
    "test:ui": "npx playwright test",
    "vscode:uninstall": "node ./uninstall-hook.js"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/MahammadNuriyev62/claude-code-katex/issues"
  },
  "homepage": "https://github.com/MahammadNuriyev62/claude-code-katex#readme",
  "jest": {
    "testPathIgnorePatterns": ["/node_modules/", "/test-ui/"]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^30.3.0"
  }
}
