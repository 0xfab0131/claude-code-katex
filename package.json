{
  "name": "claude-code-katex",
  "displayName": "Claude Code LaTeX",
  "description": "Adds LaTeX math rendering to Claude Code chat — inline $...$, display $$...$$, and \\(...\\) / \\[...\\]",
  "version": "1.8.0",
  "publisher": "nuriyev",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahammadNuriyev62/claude-code-katex.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "latex",
    "math",
    "mathematics",
    "equations",
    "katex",
    "claude",
    "claude-code",
    "anthropic",
    "markdown",
    "rendering"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-katex.enable",
        "title": "Claude Code LaTeX: Enable"
      },
      {
        "command": "claude-code-katex.disable",
        "title": "Claude Code LaTeX: Disable"
      },
      {
        "command": "claude-code-katex.status",
        "title": "Claude Code LaTeX: Status"
      },
      {
        "command": "claude-code-katex.rerender",
        "title": "Claude Code LaTeX: Re-render Math"
      }
    ]
  },
  "scripts": {
    "test": "jest",
    "test:ui": "npm run build:react-harness && npx playwright test",
    "build:react-harness": "esbuild test-ui/react-harness-entry.js --bundle --outfile=test-ui/react-harness-bundle.js --format=iife --target=es2020 --define:process.env.NODE_ENV='\"production\"'",
    "vscode:uninstall": "node ./uninstall-hook.js"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/MahammadNuriyev62/claude-code-katex/issues"
  },
  "homepage": "https://github.com/MahammadNuriyev62/claude-code-katex#readme",
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/test-ui/"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.25.0",
    "jest": "^30.3.0",
    "jsdom": "^29.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  }
}
