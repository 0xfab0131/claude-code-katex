{
  "name": "claude-code-katex",
  "displayName": "Claude Code LaTeX",
  "description": "Adds LaTeX math rendering to Claude Code chat — inline $...$, display $$...$$, and \\(...\\) / \\[...\\]",
  "version": "2.0.3",
  "publisher": "nuriyev",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahammadNuriyev62/claude-code-katex.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "latex",
    "math",
    "mathematics",
    "equations",
    "katex",
    "claude",
    "claude-code",
    "anthropic",
    "markdown",
    "rendering"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-katex.enable",
        "title": "Claude Code LaTeX: Enable"
      },
      {
        "command": "claude-code-katex.disable",
        "title": "Claude Code LaTeX: Disable"
      },
      {
        "command": "claude-code-katex.status",
        "title": "Claude Code LaTeX: Status"
      }
    ]
  },
  "scripts": {
    "test": "jest",
    "build:bundle": "esbuild v2-spike/entry.js --bundle --format=iife --minify --alias:katex=./v2-spike/katex-global-shim.js --outfile=vendor/remark-math-bundle.js",
    "vscode:uninstall": "node ./uninstall-hook.js"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/MahammadNuriyev62/claude-code-katex/issues"
  },
  "homepage": "https://github.com/MahammadNuriyev62/claude-code-katex#readme",
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.25.0",
    "jest": "^30.3.0",
    "katex": "^0.16.11",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  }
}
